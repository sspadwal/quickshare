NODE_ENV=development
PORT=5000
HOST=0.0.0.0

MONGODB_URI=mongodb+srv://user:pass@cluster.example.mongodb.net/quickshare

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Set to true if Cloudinary returns 401 on file URLs (Strict / signed delivery).
# CLOUDINARY_SIGN_DELIVERY=true

# Dev: omit CLIENT_ORIGINS for open CORS. Production: required (comma-separated origins, no path).
# Example — Vercel frontend + Render API:
# CLIENT_ORIGINS=https://quickshare-brown.vercel.app
# (Add more with commas if you use www or a Preview URL you want to allow.)

# Optional: absolute path or path relative to backend/ for built Vite app (same-origin deploy).
# Build client first: cd ../client && npm run build
# STATIC_ROOT=../client/dist

# If an old MongoDB TTL index exists on `files.expiresAt`, remove it in Atlas (Indexes)
# so rows are not deleted before the server can call Cloudinary destroy().
