# --- Local testing from a phone (same Wi‑Fi) ---
# VITE_PUBLIC_APP_ORIGIN=http://192.168.1.5:5173
# VITE_BACKEND_URL=http://192.168.1.5:5000

# --- Split deploy (e.g. Vercel frontend + Render API) ---
# Set these in Vercel → Project → Settings → Environment Variables (Production).
# Rebuild after changing. No trailing slash.
# VITE_BACKEND_URL=https://your-api.onrender.com
# Optional if QR must not use window.location: VITE_PUBLIC_APP_ORIGIN=https://your-app.vercel.app

# --- Same host as API (Express STATIC_ROOT=../client/dist) ---
# Leave VITE_BACKEND_URL unset so the app uses window.location.origin.
